# ===========================================
# Hot Monitor - 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# cp .env.example .env
# ===========================================

# OpenRouter API (必填)
# 注册地址: https://openrouter.ai/settings/keys
# 充值地址: https://openrouter.ai/settings/credits
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
OPENROUTER_MODEL=deepseek/deepseek-v4-pro

# Server
PORT=3456
NODE_ENV=development

# Monitor
SCAN_INTERVAL_MINUTES=30
SEARCH_RESULTS_PER_KEYWORD=5

# 数据源 (自动聚合以下所有来源，无需额外配置)
# ✅ Bing        - 国际搜索引擎
# ✅ Google      - 国际搜索引擎
# ✅ DuckDuckGo  - 隐私搜索引擎
# ✅ 搜狗        - 中文搜索引擎
# ✅ HackerNews  - 科技社区 (Algolia API)
# ✅ B站         - 视频平台 (官方 API)
# ✅ 微博热搜    - 实时热搜榜

# Email (可选，不填则跳过邮件通知)
# Gmail 需使用应用专用密码: https://myaccount.google.com/apppasswords
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=
